[Unit]
Description=memorygraph file watcher for %i
Documentation=https://github.com/memorygraph/memorygraph
After=network.target

[Service]
Type=simple
WorkingDirectory=%i
ExecStart=memorygraph watch --project-root %i --native
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5s
StartLimitInterval=120
StartLimitBurst=5

# Security hardening
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%i/.memorygraph
ReadOnlyPaths=%i

# Resource limits
MemoryHigh=512M
MemoryMax=1G
CPUQuota=50%

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=memorygraph-watch-%i

[Install]
WantedBy=multi-user.target
